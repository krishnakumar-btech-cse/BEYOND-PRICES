rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: farmers
    // Fields: uid, name, phone, village, district, createdAt
    //
    // Collection: crops
    // Fields: farmerId, cropName, quantity, harvestDate, hasStorage, travelRange, createdAt
    //
    // Collection: markets
    // Fields: name, location, totalStalls
    //
    // Collection: markets/{marketId}/stalls
    // Fields: marketId, stallNumber, slotTime, status
    //
    // Collection: bookings
    // Fields: farmerId, marketId, stallId, slotTime, bookingDate, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidFarmer(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.village is string && data.village.size() > 0;
    }

    function isValidCrop(data) {
      return data.farmerId is string && data.farmerId == request.auth.uid &&
             data.cropName is string && data.cropName.size() > 0 &&
             data.quantity is number && data.quantity > 0;
    }

    function isValidBooking(data) {
      return data.farmerId is string && data.farmerId == request.auth.uid &&
             data.marketId is string &&
             data.stallId is string &&
             data.status in ['confirmed', 'cancelled'];
    }

    // Rules
    match /farmers/{farmerId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(farmerId) && isValidFarmer(request.resource.data);
      allow update: if isOwner(farmerId) && isValidFarmer(request.resource.data);
    }

    match /crops/{cropId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCrop(request.resource.data);
      allow update: if isAuthenticated() && resource.data.farmerId == request.auth.uid && isValidCrop(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.farmerId == request.auth.uid;
    }

    match /markets/{marketId} {
      allow read: if true;
      allow create, update, delete: if false; // Admin only via console
    }

    match /stalls/{stallId} {
      allow read: if true;
      allow update: if 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['available', 'booked'];
      allow create, delete: if false; // Pre-seeded or admin only
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true; // Anonymous booking
      allow update: if request.resource.data.status in ['confirmed', 'cancelled'];
      allow delete: if false; // No deletion allowed for demo audits
    }
  }
}
